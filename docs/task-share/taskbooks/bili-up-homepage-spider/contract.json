{
	"outputDir": "<runtime>",
	"artifacts": [
		"bilibili_videos_page{page}.json"
	],
	"runtimeInput": [
		"url",
		"page"
	],
	"runtimeInputMeta": {
		"url": {
			"description": "B站UP主主页视频标签链接，格式 https://space.bilibili.com/{uid}/upload/video",
			"required": true
		},
		"page": {
			"description": "页码，从1开始",
			"required": false,
			"default": 1
		}
	},
	"requiredTools": [
		"chrome_cdp"
	]
}
