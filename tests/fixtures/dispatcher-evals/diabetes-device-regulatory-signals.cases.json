{
	"task": "diabetes-device-regulatory-signals",
	"description": "diabetes-device-regulatory-signals dispatcher eval。核心难点:相对时间窗口、30 天上限、sourceFilter 枚举。采集 task 不再接收 targetLanguage。",
	"cases": [
		{
			"id": "ddrs-01",
			"group": "baseline",
			"input": "最近7天糖尿病医疗器械监管信号",
			"assert": {
				"timePhrase": "equals:最近7天",
				"days": "equals:7",
				"startIso": "present",
				"endIso": "present",
				"maxItems": "in:omitted|100",
				"targetLanguage": "absent",
				"sourceFilter": "in:omitted|all"
			},
			"note": "默认全源、原文报告标签。"
		},
		{
			"id": "ddrs-02",
			"group": "language",
			"input": "最近7天，输出中文版本",
			"assert": {
				"days": "equals:7",
				"startIso": "present",
				"endIso": "present",
				"targetLanguage": "absent",
				"sourceFilter": "in:omitted|all"
			},
			"note": "中文版本由 renderer 处理。"
		},
		{
			"id": "ddrs-03",
			"group": "window",
			"input": "最近一个月糖尿病设备监管数据库信号，最多50条",
			"assert": {
				"days": "equals:30",
				"maxItems": "equals:50",
				"startIso": "present",
				"endIso": "present"
			},
			"note": "最近一个月按 30 天。"
		},
		{
			"id": "ddrs-04",
			"group": "boundary",
			"input": "最近45天，最多500条，中文",
			"assert": {
				"days": "equals:30",
				"maxItems": "equals:300",
				"targetLanguage": "absent",
				"startIso": "present",
				"endIso": "present"
			},
			"note": "days 和 maxItems 都必须封顶。"
		},
		{
			"id": "ddrs-05",
			"group": "source-filter",
			"input": "最近30天只看 openFDA recalls",
			"assert": {
				"days": "equals:30",
				"sourceFilter": "equals:openfda-recall",
				"startIso": "present",
				"endIso": "present"
			},
			"note": "recalls only 应映射 openfda-recall。"
		},
		{
			"id": "ddrs-06",
			"group": "source-filter",
			"input": "past week ClinicalTrials only, Chinese report",
			"assert": {
				"days": "equals:7",
				"sourceFilter": "equals:clinicaltrials",
				"targetLanguage": "absent",
				"startIso": "present",
				"endIso": "present"
			},
			"note": "英文别名 ClinicalTrials only; Chinese 由 renderer 处理。"
		},
		{
			"id": "ddrs-07",
			"group": "source-filter",
			"input": "最近7天只看 510(k) 获批",
			"assert": {
				"days": "equals:7",
				"sourceFilter": "equals:openfda-510k",
				"startIso": "present",
				"endIso": "present"
			},
			"note": "510(k)/获批映射 openfda-510k。"
		},
		{
			"id": "ddrs-08",
			"group": "phase-2.5-source-filter",
			"input": "最近30天只看 FDA CDRH 官方更新",
			"assert": {
				"days": "equals:30",
				"sourceFilter": "equals:fda-cdrh",
				"startIso": "present",
				"endIso": "present"
			},
			"note": "FDA CDRH 官方更新映射 fda-cdrh。"
		},
		{
			"id": "ddrs-09",
			"group": "phase-2.5-source-filter",
			"input": "最近30天只看 FDA medical device safety early alerts",
			"assert": {
				"days": "equals:30",
				"sourceFilter": "equals:fda-device-safety",
				"startIso": "present",
				"endIso": "present"
			},
			"note": "FDA safety/early alerts 映射 fda-device-safety。"
		},
		{
			"id": "ddrs-10",
			"group": "phase-2.5-source-filter",
			"input": "最近30天只看 ADA Scientific Sessions 官方会议信号",
			"assert": {
				"days": "equals:30",
				"sourceFilter": "equals:ada",
				"startIso": "present",
				"endIso": "present"
			},
			"note": "ADA Scientific Sessions 映射 ada。"
		},
		{
			"id": "ddrs-11",
			"group": "phase-2.5-source-filter",
			"input": "最近30天只看 ATTD 会议糖尿病设备新闻",
			"assert": {
				"days": "equals:30",
				"sourceFilter": "equals:attd",
				"startIso": "present",
				"endIso": "present"
			},
			"note": "ATTD 映射 attd。"
		},
		{
			"id": "ddrs-12",
			"group": "phase-2.5-source-filter",
			"input": "最近30天只看 EASD 年会糖尿病医疗器械信号",
			"assert": {
				"days": "equals:30",
				"sourceFilter": "equals:easd",
				"startIso": "present",
				"endIso": "present"
			},
			"note": "EASD 年会映射 easd。"
		}
	]
}
