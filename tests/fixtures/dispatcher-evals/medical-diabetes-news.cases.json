{
	"task": "medical-diabetes-news",
	"description": "medical-diabetes-news dispatcher eval。核心难点：相对时间窗口计算、最多一个月上限、maxItems 上限。采集 task 不再接收 targetLanguage。",
	"cases": [
		{
			"id": "med-news-01",
			"group": "baseline",
			"input": "最近7天",
			"assert": {
				"timePhrase": "equals:最近7天",
				"days": "equals:7",
				"startIso": "present",
				"endIso": "present",
				"maxItems": "in:omitted|100",
				"targetLanguage": "absent"
			},
			"note": "默认：最近7天；语言交给 renderer。"
		},
		{
			"id": "med-news-02",
			"group": "language",
			"input": "最近7天，输出中文版本",
			"assert": {
				"days": "equals:7",
				"startIso": "present",
				"endIso": "present",
				"targetLanguage": "absent"
			},
			"note": "采集 task 忽略中文版本；语言交给 renderer。"
		},
		{
			"id": "med-news-03",
			"group": "window",
			"input": "最近3天糖尿病医疗器械新闻",
			"assert": {
				"days": "equals:3",
				"startIso": "present",
				"endIso": "present",
				"targetLanguage": "absent"
			},
			"note": "最近3天应映射 days=3。"
		},
		{
			"id": "med-news-04",
			"group": "window",
			"input": "最近一个月，最多50条",
			"assert": {
				"days": "equals:30",
				"maxItems": "equals:50",
				"startIso": "present",
				"endIso": "present"
			},
			"note": "最近一个月按 30 天；明确最多50条应进入 maxItems。"
		},
		{
			"id": "med-news-05",
			"group": "boundary",
			"input": "最近45天，糖尿病新闻",
			"assert": {
				"days": "equals:30",
				"targetLanguage": "absent",
				"startIso": "present",
				"endIso": "present"
			},
			"note": "超过一个月必须封顶 30 天。"
		},
		{
			"id": "med-news-06",
			"group": "boundary",
			"input": "最近7天，最多500条",
			"assert": {
				"days": "equals:7",
				"maxItems": "equals:300",
				"startIso": "present",
				"endIso": "present"
			},
			"note": "maxItems hard maximum 是 300。"
		},
		{
			"id": "med-news-07",
			"group": "english",
			"input": "past week diabetes device news in Chinese",
			"assert": {
				"days": "equals:7",
				"startIso": "present",
				"endIso": "present",
				"targetLanguage": "absent"
			},
			"note": "英文表达：past week 是 7 天；Chinese 由 renderer 处理。"
		},
		{
			"id": "med-news-08",
			"group": "vague",
			"input": "帮我抓取最新糖尿病医疗器械新闻",
			"assert": {
				"days": "equals:7",
				"startIso": "present",
				"endIso": "present",
				"targetLanguage": "absent"
			},
			"note": "模糊最新按 contract 默认 7 天。"
		}
	]
}