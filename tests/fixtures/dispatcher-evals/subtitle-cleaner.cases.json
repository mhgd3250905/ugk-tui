{
	"task": "subtitle-cleaner",
	"description": "subtitle-cleaner dispatcher eval。单必填字段 subtitlePath,翻译难度低,主要测路径原样提取和必填缺失边界。",
	"cases": [
		{
			"id": "clean-01",
			"group": "baseline",
			"input": "清洗 E:/subs/raw.srt",
			"assert": {
				"subtitlePath": "path-equals:E:/subs/raw.srt"
			},
			"note": "基线:路径原样提取"
		},
		{
			"id": "clean-02",
			"group": "baseline",
			"input": "E:/subs/raw.vtt",
			"assert": {
				"subtitlePath": "path-equals:E:/subs/raw.vtt"
			},
			"note": "基线:裸路径"
		},
		{
			"id": "clean-03",
			"group": "baseline",
			"input": "把 D:/downloads/sub.ttml 这个字幕清理一下",
			"assert": {
				"subtitlePath": "path-equals:D:/downloads/sub.ttml"
			},
			"note": "基线:TTML 格式,从句子里提取路径"
		},
		{
			"id": "clean-04",
			"group": "alias",
			"input": "clean up E:/subs/dirty.srt please",
			"assert": {
				"subtitlePath": "path-equals:E:/subs/dirty.srt"
			},
			"note": "别名(英文):路径提取"
		},
		{
			"id": "clean-05",
			"group": "alias",
			"input": "这个 E:/output/transcript.vtt 帮我归一化处理",
			"assert": {
				"subtitlePath": "path-equals:E:/output/transcript.vtt"
			},
			"note": "别名:'归一化处理' → 清洗,路径提取"
		},
		{
			"id": "clean-06",
			"group": "boundary",
			"input": "清洗一下字幕",
			"assert": {
				"__outcome": "fails-required-gate"
			},
			"note": "边界:无路径(必填缺失),应解析失败"
		},
		{
			"id": "clean-07",
			"group": "boundary",
			"input": "清洗 E:/subs/raw.srt 去掉回声碎片",
			"assert": {
				"subtitlePath": "path-equals:E:/subs/raw.srt"
			},
			"note": "边界:'去掉回声碎片'是清洗的具体要求,不是输入字段。dispatcher 不该把它塞进 subtitlePath 或编造字段。"
		},
		{
			"id": "clean-08",
			"group": "boundary",
			"input": "清洗 E:/path with space/raw.srt",
			"assert": {
				"subtitlePath": "path-equals:E:/path with space/raw.srt"
			},
			"note": "边界:路径含空格,必须原样提取完整路径,不能截断成 E:/path"
		}
	]
}
